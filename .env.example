# =============================================================================
# ROYAL NOMAD RIDERS CLUB — ENVIRONMENT VARIABLES
# Copy this file to .env (local dev) and configure the same keys in your
# Vercel project settings for production/preview deployments.
# =============================================================================

# -----------------------------------------------------------------------------
# SITE CONFIG
# -----------------------------------------------------------------------------
# Public base URL of the deployed site (no trailing slash). Used for canonical
# URLs, sitemap.xml, robots.txt, Open Graph, and JSON-LD.
NEXT_PUBLIC_SITE_URL="https://royalnomadriders.com"
NEXT_PUBLIC_SITE_NAME="Royal Nomad Riders Club"

# -----------------------------------------------------------------------------
# SUPABASE
# Found in: Supabase Dashboard -> Project Settings -> API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
# Service role key — server-only, NEVER expose with NEXT_PUBLIC_ prefix.
# Used for admin-level operations (bulk uploads, CSV export, role management).
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# -----------------------------------------------------------------------------
# DATABASE (Supabase Postgres, used by Prisma)
# Found in: Supabase Dashboard -> Project Settings -> Database
# Use the pooled "Transaction" connection string for DATABASE_URL (runtime)
# and the direct connection string for DIRECT_URL (migrations).
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# EMAIL (transactional — registration confirmations, contact form, newsletter)
# Using Resend (free tier: 3,000 emails/month, 100/day)
# -----------------------------------------------------------------------------
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="Royal Nomad Riders Club <rides@royalnomadriders.com>"
EMAIL_REPLY_TO="contact@royalnomadriders.com"

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# Random 32+ character secret used to sign internal tokens (CSV export links,
# unsubscribe tokens). Generate with: openssl rand -base64 32
APP_SECRET="generate-a-long-random-secret-value"

# Shared secret checked by /api/cron/archive-events (see vercel.json). Vercel
# automatically sends this as a Bearer token for its own Cron Job invocations
# when set as CRON_SECRET in your Vercel project's environment variables —
# generate with: openssl rand -base64 32
CRON_SECRET="generate-a-long-random-secret-value"

# Rate limiting (Upstash Redis free tier) — protects auth, contact & registration
# routes from abuse. Leave blank to fall back to in-memory limiting (single
# instance only — fine for low traffic, upgrade before scaling horizontally).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# THIRD-PARTY / SOCIAL (used in Phase 2+ for the Instagram feed section)
# -----------------------------------------------------------------------------
INSTAGRAM_ACCESS_TOKEN=""
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=""

# -----------------------------------------------------------------------------
# ANALYTICS / SEO VERIFICATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""
NEXT_PUBLIC_VERCEL_ANALYTICS="true"
